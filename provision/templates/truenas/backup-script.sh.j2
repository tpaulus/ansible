#!/usr/bin/env bash

{{ ansible_managed | comment }}

RESTIC="/usr/bin/restic"

export RESTIC_PASSWORD="{{ restic_password }}"
export B2_ACCOUNT_ID="{{ b2_account_id }}"
export B2_ACCOUNT_KEY="{{ b2_account_key }}"

BUCKET_NAME="{{ b2_bucket_name }}"
SHARES_TO_BACKUP="{{ shares | join(' ') }}"  # Separate by Spaces

# Retry configuration
MAX_RETRIES="${MAX_RETRIES:-3}"
BASE_RETRY_DELAY="${BASE_RETRY_DELAY:-30}"
MAX_RETRY_DELAY="${MAX_RETRY_DELAY:-300}"
BACKUP_TIMEOUT_SECONDS="${BACKUP_TIMEOUT_SECONDS:-7200}"
INIT_TIMEOUT_SECONDS="${INIT_TIMEOUT_SECONDS:-600}"
BACKUP_KILL_AFTER="${BACKUP_KILL_AFTER:-5m}"
INIT_KILL_AFTER="${INIT_KILL_AFTER:-30s}"
LOCK_RETRY_DURATION="${LOCK_RETRY_DURATION:-5m}"
STUCK_REQUEST_TIMEOUT="${STUCK_REQUEST_TIMEOUT:-5m}"

calculate_retry_delay() {
    local retry=$1
    local delay=$((BASE_RETRY_DELAY * (2 ** (retry - 1))))

    if [ "$delay" -gt "$MAX_RETRY_DELAY" ]; then
        delay=$MAX_RETRY_DELAY
    fi

    echo "$delay"
}

# Install (or update) Restic
if [ ! -f "$RESTIC" ]; then
    curl -s https://api.github.com/repos/restic/restic/releases/latest \
    | grep "_linux_amd64.bz2" \
    | cut -d : -f 2,3 \
    | tr -d \" \
    | tail -n 1 \
    | xargs wget -O /tmp/restic.bz2

    bunzip2 /tmp/restic.bz2
    mv /tmp/restic "$RESTIC"
    chmod +x "$RESTIC"
else
    $RESTIC self-update
fi

# Function to initialize repository with retry logic
init_repo() {
    local bucket=$1
    local share=$2
    local retry=0
    local init_output
    local init_exit_code

    while [ $retry -lt $MAX_RETRIES ]; do
        echo "Initializing repo for $share (attempt $((retry + 1))/$MAX_RETRIES)"
        
        # Try to unlock first in case of stale locks
        $RESTIC --retry-lock "$LOCK_RETRY_DURATION" --stuck-request-timeout "$STUCK_REQUEST_TIMEOUT" unlock -r "b2:${bucket}:${share}" 2>/dev/null || true
        
        init_output=$(timeout --kill-after="$INIT_KILL_AFTER" "$INIT_TIMEOUT_SECONDS" \
            "$RESTIC" --retry-lock "$LOCK_RETRY_DURATION" --stuck-request-timeout "$STUCK_REQUEST_TIMEOUT" \
            -r "b2:${bucket}:${share}" init 2>&1)
        init_exit_code=$?

        if [ $init_exit_code -eq 0 ]; then
            echo "Successfully initialized repo for $share"
            return 0
        elif [ $init_exit_code -eq 124 ]; then
            echo "Repository initialization for $share exceeded timeout (${INIT_TIMEOUT_SECONDS}s), unlocking repository."
            $RESTIC --retry-lock "$LOCK_RETRY_DURATION" --stuck-request-timeout "$STUCK_REQUEST_TIMEOUT" unlock -r "b2:${bucket}:${share}" 2>/dev/null || true
        elif echo "$init_output" | grep -q "already initialized"; then
            echo "Repo for $share already initialized"
            return 0
        else
            echo "Failed to initialize repo for $share: $init_output"
        fi

        retry=$((retry + 1))
        if [ $retry -lt $MAX_RETRIES ]; then
            local retry_delay
            retry_delay=$(calculate_retry_delay "$retry")
            echo "Failed to initialize repo for $share, retrying in ${retry_delay}s..."
            sleep "$retry_delay"
        fi
    done

    echo "Failed to initialize repo for $share after $MAX_RETRIES attempts"
    return 1
}

# Function to perform backup with retry logic
backup_share() {
    local bucket=$1
    local share=$2
    local retry=0
    local backup_success=false

    while [ $retry -lt $MAX_RETRIES ]; do
        echo "Backing up ${share} (attempt $((retry + 1))/$MAX_RETRIES)"
        timeout --kill-after="$BACKUP_KILL_AFTER" "$BACKUP_TIMEOUT_SECONDS" "$RESTIC" \
            --retry-lock "$LOCK_RETRY_DURATION" --stuck-request-timeout "$STUCK_REQUEST_TIMEOUT" \
            backup \
            --cleanup-cache \
            -r "b2:${bucket}:${share}" \
            "/mnt/tank/${share}"

        local backup_exit_code=$?

        if [ $backup_exit_code -eq 0 ]; then
            echo "Successfully backed up ${share}"
            echo "b2_backup_completed{share=\"${share}\", bucket_name=\"${bucket}\"}" $(date +%s) >> /var/lib/node_exporter/b2_backup.prom.$$
            backup_success=true
            break
        elif [ $backup_exit_code -eq 124 ]; then
            echo "Backup for ${share} exceeded timeout (${BACKUP_TIMEOUT_SECONDS}s), unlocking repository."
            echo "b2_backup_timeout{share=\"${share}\", bucket_name=\"${bucket}\"}" $(date +%s) >> /var/lib/node_exporter/b2_backup.prom.$$
            $RESTIC --retry-lock "$LOCK_RETRY_DURATION" --stuck-request-timeout "$STUCK_REQUEST_TIMEOUT" unlock -r "b2:${bucket}:${share}" 2>/dev/null || true
        else
            echo "Backup for ${share} failed with exit code $backup_exit_code"
            echo "b2_backup_failed{share=\"${share}\", bucket_name=\"${bucket}\", exit_code=\"${backup_exit_code}\"}" $(date +%s) >> /var/lib/node_exporter/b2_backup.prom.$$
            # Attempt to unlock in case of partial lock
            $RESTIC --retry-lock "$LOCK_RETRY_DURATION" --stuck-request-timeout "$STUCK_REQUEST_TIMEOUT" unlock -r "b2:${bucket}:${share}" 2>/dev/null || true
        fi

        retry=$((retry + 1))
        if [ $retry -lt $MAX_RETRIES ] && [ "$backup_success" = false ]; then
            local retry_delay
            retry_delay=$(calculate_retry_delay "$retry")
            echo "Retrying backup for ${share} in ${retry_delay}s..."
            sleep "$retry_delay"
        fi
    done

    if [ "$backup_success" = true ]; then
        return 0
    else
        echo "Failed to backup ${share} after $MAX_RETRIES attempts"
        return 1
    fi
}

for share in $SHARES_TO_BACKUP
do
    echo "Processing share: ${share}"

    # If not initialized
    if ! $RESTIC --retry-lock "$LOCK_RETRY_DURATION" --stuck-request-timeout "$STUCK_REQUEST_TIMEOUT" -r "b2:${BUCKET_NAME}:${share}" snapshots > /dev/null 2>&1; then
        echo "Repo for $share not initialized"
        if ! init_repo "$BUCKET_NAME" "$share"; then
            echo "Skipping ${share} due to initialization failure"
            continue
        fi
    fi

    # Backup with retry
    if backup_share "$BUCKET_NAME" "$share"; then
        echo "Finished backing up ${share}. Starting cleanup."
        
        # Run cleanup
        if $RESTIC --retry-lock "$LOCK_RETRY_DURATION" --stuck-request-timeout "$STUCK_REQUEST_TIMEOUT" forget \
            -r "b2:${BUCKET_NAME}:${share}" \
            --keep-daily 7 \
            --keep-weekly 5 \
            --keep-monthly 7 \
            --prune; then
            echo "b2_cleanup_completed{share=\"${share}\", bucket_name=\"${BUCKET_NAME}\"}" $(date +%s) >> /var/lib/node_exporter/b2_backup.prom.$$
            echo "Cleanup finished for $share"
        else
            echo "Cleanup failed for $share, but backup was successful"
        fi
    else
        echo "Skipping cleanup for ${share} due to backup failure"
    fi

done

mv /var/lib/node_exporter/b2_backup.prom.$$ /var/lib/node_exporter/b2_backup.prom
echo "Backup Completed"

unset RESTIC_PASSWORD
unset B2_ACCOUNT_ID
unset B2_ACCOUNT_KEY
